unit UnitMain;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes,
  Vcl.Graphics, Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.StdCtrls,
  FlexgetConfigDTO, Vcl.ComCtrls, Vcl.ExtCtrls; // Removido Vcl.Samples.Spin

type
  TFormMain = class(TForm)
    btnLoadConfig: TButton;
    OpenDialog1: TOpenDialog;
    PageControl: TPageControl;
    tsAlteracoes: TTabSheet;
    tsDebug: TTabSheet;
    MemoConfigRaw: TMemo;
    MemoParsedInfo: TMemo;
    Label1: TLabel;
    Label2: TLabel;
    tvConfig: TTreeView;
    Splitter1: TSplitter;
    pnlDetails: TScrollBox;
    lblAcceptAll: TLabel;
    edtAcceptAll: TEdit;
    lblMagnets: TLabel;
    edtMagnets: TEdit;
    lblContentSize: TLabel;
    edtContentSize: TEdit;
    lblRegexp: TLabel;
    memRegexp: TMemo;
    lblRssUrl: TLabel;
    edtRssUrl: TEdit;
    lblRssAllEntries: TLabel;
    edtRssAllEntries: TEdit;
    lblTaskTemplates: TLabel;
    memTaskTemplates: TMemo;
    lblQbitHost: TLabel;
    edtQbitHost: TEdit;
    lblQbitPort: TLabel;
    edtQbitPort: TEdit;
    lblQbitUser: TLabel;
    edtQbitUser: TEdit;
    lblQbitPass: TLabel;
    edtQbitPass: TEdit;
    lblQbitPath: TLabel;
    edtQbitPath: TEdit;
    btnSaveChanges: TButton;
    SaveDialog1: TSaveDialog;
    lblScheduleTasks: TLabel;
    edtScheduleTasks: TEdit;
    lblScheduleInterval: TLabel;
    edtScheduleInterval: TEdit;
    procedure btnLoadConfigClick(Sender: TObject);
    procedure FormCreate(Sender: TObject);
    procedure FormDestroy(Sender: TObject);
    procedure tvConfigChange(Sender: TObject; Node: TTreeNode);
    procedure btnSaveChangesClick(Sender: TObject);
  private
    { Private declarations }
    FConfig: TFlexgetConfigDTO;
    procedure LoadConfigFromFile(const AFileName: string);
    procedure PopulateUI;
    procedure ShowDebugInfo;
    procedure PopulateTreeView;
    procedure UpdateDTOFromUI;
    procedure SaveChangesToFile;
    procedure ShowDetailsForNode(ANode: TTreeNode);
    procedure ShowTemplateDetails(const ATemplate: TTemplateDTO);
    procedure ShowTaskDetails(const ATask: TTaskDTO);
    procedure ShowScheduleDetails(const ASchedule: TScheduleDTO);
    procedure SetAllDetailsVisibility(AVisible: Boolean);
  public
    { Public declarations }
  end;

var
  FormMain: TFormMain;

implementation

{$R *.dfm}

//--- Métodos Principais de Gerenciamento ---

procedure TFormMain.FormCreate(Sender: TObject);
begin
  FConfig := TFlexgetConfigDTO.Create;
  // Oculta todos os painéis de detalhes inicialmente
  SetAllDetailsVisibility(False);
end;

procedure TFormMain.FormDestroy(Sender: TObject);
begin
  FConfig.Free;
end;

procedure TFormMain.LoadConfigFromFile(const AFileName: string);
begin
  try
    FConfig.LoadFromYamlFile(AFileName);
    MemoConfigRaw.Lines.LoadFromFile(AFileName);
    PopulateUI;
    btnSaveChanges.Enabled := True;
    PageControl.ActivePage := tsAlteracoes;
    ShowMessage('Arquivo carregado com sucesso!');
  except
    on E: Exception do
      ShowMessage('Erro ao carregar arquivo: ' + E.Message);
  end;
end;

procedure TFormMain.SaveChangesToFile;
begin
  UpdateDTOFromUI; // Garante que os dados do DTO estão atualizados com a UI

  SaveDialog1.FileName := OpenDialog1.FileName;
  if SaveDialog1.Execute then
  begin
    try
      MemoConfigRaw.Lines.Text := FConfig.ToYamlString;
      MemoConfigRaw.Lines.SaveToFile(SaveDialog1.FileName);
      ShowMessage('Alterações salvas com sucesso!');
    except
      on E: Exception do
      begin
        ShowMessage('Erro ao salvar o arquivo: ' + E.Message);
      end;
    end;
  end;
end;


//--- Lógica de Preenchimento da UI ---

procedure TFormMain.PopulateUI;
begin
  ShowDebugInfo;
  PopulateTreeView;
end;

procedure TFormMain.ShowDebugInfo;
var
  LKey: string;
  LTemplate: TTemplateDTO;
  LTask: TTaskDTO;
  LSchedule: TScheduleDTO;
begin
  MemoParsedInfo.Clear;
  MemoParsedInfo.Lines.BeginUpdate;
  try
    MemoParsedInfo.Lines.Add('=== Templates ===');
    for LKey in FConfig.Templates.Keys do
    begin
      LTemplate := FConfig.Templates[LKey];
      MemoParsedInfo.Lines.Add('Template: ' + LKey);
      MemoParsedInfo.Lines.Add('  AcceptAll: ' + LTemplate.AcceptAll);
      MemoParsedInfo.Lines.Add('  Regexp Accept: ' + LTemplate.RegexpAccept.Text.Replace(#13#10, ', ', [rfReplaceAll]).Trim);
      MemoParsedInfo.Lines.Add('  ContentSize Min: ' + IntToStr(LTemplate.ContentSizeMin));
      MemoParsedInfo.Lines.Add('  Magnets: ' + LTemplate.Magnets);
      MemoParsedInfo.Lines.Add('');
    end;

    MemoParsedInfo.Lines.Add('=== Tasks ===');
    for LKey in FConfig.Tasks.Keys do
    begin
      LTask := FConfig.Tasks[LKey];
      MemoParsedInfo.Lines.Add('Task: ' + LKey);
      MemoParsedInfo.Lines.Add('  RSS URL: ' + LTask.Rss.Url);
      MemoParsedInfo.Lines.Add('  Templates: ' + LTask.Template.Text.Replace(#13#10, ', ', [rfReplaceAll]).Trim);
      MemoParsedInfo.Lines.Add('  QBittorrent Host: ' + LTask.Qbittorrent.Host);
      MemoParsedInfo.Lines.Add('  QBittorrent Path: ' + LTask.Qbittorrent.Path);
      MemoParsedInfo.Lines.Add('');
    end;

    MemoParsedInfo.Lines.Add('=== Schedules ===');
    var LIndex := 0;
    for LSchedule in FConfig.Schedules do
    begin
      MemoParsedInfo.Lines.Add(Format('Schedule [%d]', [LIndex]));
      MemoParsedInfo.Lines.Add('  Tasks: ' + LSchedule.Tasks);
      MemoParsedInfo.Lines.Add('  Interval Minutes: ' + IntToStr(LSchedule.IntervalMinutes));
      MemoParsedInfo.Lines.Add('');
      Inc(LIndex);
    end;
  finally
    MemoParsedInfo.Lines.EndUpdate;
  end;
end;

procedure TFormMain.PopulateTreeView;
var
  LRootNode, LChildNode: TTreeNode;
  LKey: string;
  LSchedule: TScheduleDTO;
  LIndex: Integer;
begin
  tvConfig.Items.BeginUpdate;
  try
    tvConfig.Items.Clear;

    // Node Templates
    LRootNode := tvConfig.Items.Add(nil, 'Templates');
    for LKey in FConfig.Templates.Keys do
      LChildNode := tvConfig.Items.AddChildObject(LRootNode, LKey, FConfig.Templates[LKey]);

    // Node Tasks
    LRootNode := tvConfig.Items.Add(nil, 'Tasks');
    for LKey in FConfig.Tasks.Keys do
      LChildNode := tvConfig.Items.AddChildObject(LRootNode, LKey, FConfig.Tasks[LKey]);

    // Node Schedules
    LRootNode := tvConfig.Items.Add(nil, 'Schedules');
    LIndex := 0;
    for LSchedule in FConfig.Schedules do
    begin
      LChildNode := tvConfig.Items.AddChildObject(LRootNode, Format('Schedule [%d]', [LIndex]), LSchedule);
      Inc(LIndex);
    end;

    tvConfig.FullExpand;
  finally
    tvConfig.Items.EndUpdate;
  end;
end;


//--- Lógica de Exibição dos Detalhes ---

procedure TFormMain.SetAllDetailsVisibility(AVisible: Boolean);
var
  i: integer;
begin
  // Itera por todos os componentes no painel de detalhes e os oculta/mostra
  for i := 0 to pnlDetails.ComponentCount - 1 do
    if pnlDetails.Components[i] is TControl then
      (pnlDetails.Components[i] as TControl).Visible := AVisible;
end;

procedure TFormMain.ShowDetailsForNode(ANode: TTreeNode);
begin
  SetAllDetailsVisibility(False);
  if not Assigned(ANode) or not Assigned(ANode.Data) then
    Exit;

  UpdateDTOFromUI; // Salva alterações do item anterior antes de mostrar o novo

  if ANode.Data is TTemplateDTO then
    ShowTemplateDetails(TTemplateDTO(ANode.Data))
  else if ANode.Data is TTaskDTO then
    ShowTaskDetails(TTaskDTO(ANode.Data))
  else if ANode.Data is TScheduleDTO then
    ShowScheduleDetails(TScheduleDTO(ANode.Data));
end;

procedure TFormMain.ShowTemplateDetails(const ATemplate: TTemplateDTO);
begin
  // Mostra apenas os controles relevantes para Template
  lblAcceptAll.Visible := True; edtAcceptAll.Visible := True;
  lblMagnets.Visible := True; edtMagnets.Visible := True;
  lblContentSize.Visible := True; edtContentSize.Visible := True;
  lblRegexp.Visible := True; memRegexp.Visible := True;

  // Preenche com os dados
  edtAcceptAll.Text := ATemplate.AcceptAll;
  edtMagnets.Text := ATemplate.Magnets;
  edtContentSize.Text := ATemplate.ContentSizeMin.ToString;
  memRegexp.Lines.Assign(ATemplate.RegexpAccept);
end;

procedure TFormMain.ShowTaskDetails(const ATask: TTaskDTO);
begin
  // Mostra apenas os controles relevantes para Task
  lblRssUrl.Visible := True; edtRssUrl.Visible := True;
  lblRssAllEntries.Visible := True; edtRssAllEntries.Visible := True;
  lblTaskTemplates.Visible := True; memTaskTemplates.Visible := True;
  lblQbitHost.Visible := True; edtQbitHost.Visible := True;
  lblQbitPort.Visible := True; edtQbitPort.Visible := True;
  lblQbitUser.Visible := True; edtQbitUser.Visible := True;
  lblQbitPass.Visible := True; edtQbitPass.Visible := True;
  lblQbitPath.Visible := True; edtQbitPath.Visible := True;

  // Preenche com os dados
  edtRssUrl.Text := ATask.Rss.Url;
  edtRssAllEntries.Text := ATask.Rss.AllEntries;
  memTaskTemplates.Lines.Assign(ATask.Template);
  edtQbitHost.Text := ATask.Qbittorrent.Host;
  edtQbitPort.Text := ATask.Qbittorrent.Port.ToString;
  edtQbitUser.Text := ATask.Qbittorrent.Username;
  edtQbitPass.Text := ATask.Qbittorrent.Password;
  edtQbitPath.Text := ATask.Qbittorrent.Path;
end;

procedure TFormMain.ShowScheduleDetails(const ASchedule: TScheduleDTO);
begin
  // Mostra apenas os controles relevantes para Schedule
  lblScheduleTasks.Visible := True; edtScheduleTasks.Visible := True;
  lblScheduleInterval.Visible := True; edtScheduleInterval.Visible := True;

  // Preenche com os dados
  edtScheduleTasks.Text := ASchedule.Tasks;
  edtScheduleInterval.Text := ASchedule.IntervalMinutes.ToString;
end;

//--- Lógica de Atualização do DTO ---

procedure TFormMain.UpdateDTOFromUI;
var
  LNode: TTreeNode;
  LTemplate: TTemplateDTO;
  LTask: TTaskDTO;
  LSchedule: TScheduleDTO;
begin
  LNode := tvConfig.Selected;
  if not Assigned(LNode) or not Assigned(LNode.Data) then
    Exit;

  if LNode.Data is TTemplateDTO then
  begin
    LTemplate := TTemplateDTO(LNode.Data);
    LTemplate.AcceptAll := edtAcceptAll.Text;
    LTemplate.Magnets := edtMagnets.Text;
    LTemplate.ContentSizeMin := StrToIntDef(edtContentSize.Text, 0);
    LTemplate.RegexpAccept.Assign(memRegexp.Lines);
  end
  else if LNode.Data is TTaskDTO then
  begin
    LTask := TTaskDTO(LNode.Data);
    LTask.Rss.Url := edtRssUrl.Text;
    LTask.Rss.AllEntries := edtRssAllEntries.Text;
    LTask.Template.Assign(memTaskTemplates.Lines);
    LTask.Qbittorrent.Host := edtQbitHost.Text;
    LTask.Qbittorrent.Port := StrToIntDef(edtQbitPort.Text, 0);
    LTask.Qbittorrent.Username := edtQbitUser.Text;
    LTask.Qbittorrent.Password := edtQbitPass.Text;
    LTask.Qbittorrent.Path := edtQbitPath.Text;
  end
  else if LNode.Data is TScheduleDTO then
  begin
    LSchedule := TScheduleDTO(LNode.Data);
    LSchedule.Tasks := edtScheduleTasks.Text;
    LSchedule.IntervalMinutes := StrToIntDef(edtScheduleInterval.Text, 0);
  end;
end;

//--- Event Handlers ---

procedure TFormMain.btnLoadConfigClick(Sender: TObject);
begin
  if OpenDialog1.Execute then
  begin
    LoadConfigFromFile(OpenDialog1.FileName);
  end;
end;

procedure TFormMain.btnSaveChangesClick(Sender: TObject);
begin
  SaveChangesToFile;
end;

procedure TFormMain.tvConfigChange(Sender: TObject; Node: TTreeNode);
begin
  ShowDetailsForNode(Node);
end;

end.