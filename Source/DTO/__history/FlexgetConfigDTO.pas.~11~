unit FlexgetConfigDTO;

interface

uses
  System.SysUtils, System.Classes, System.Generics.Collections, System.StrUtils;

type
  TTemplateDTO = class(TPersistent)
  public
    AcceptAll: string;
    RegexpAccept: TStringList;
    ContentSizeMin: Integer;
    Magnets: string;
    constructor Create;
    destructor Destroy; override;
  end;

  // Simplificado: ContÚm apenas as configuraþ§es globais de qBittorrent
  TQbittorrentDTO = class(TPersistent)
  public
    Host: string;
    Port: Integer;
    Username: string;
    Password: string;
  end;

  // Simplificado: ContÚm apenas as configuraþ§es individuais por tarefa
  TTaskDTO = class(TPersistent)
  public
    RssUrl: string;
    QbitPath: string; // O 'path' agora Ú individual por tarefa
  end;

  TScheduleDTO = class(TPersistent)
  public
    Tasks: string;
    IntervalMinutes: Integer;
  end;

  // NOVA CLASSE: Para armazenar todas as configuraþ§es padrÒo/globais
  TConfigDefaultsDTO = class(TPersistent)
  public
    Qbittorrent: TQbittorrentDTO;
    RssAllEntries: string;
    DefaultTemplates: TStringList;
    constructor Create;
    destructor Destroy; override;
  end;

  TFlexgetConfigDTO = class(TPersistent)
  public
    Defaults: TConfigDefaultsDTO; // Novo objeto para configuraþ§es padrÒo
    Templates: TDictionary<string, TTemplateDTO>;
    Tasks: TDictionary<string, TTaskDTO>;
    Schedules: TObjectList<TScheduleDTO>;

    constructor Create;
    destructor Destroy; override;

    procedure LoadFromYamlFile(const AFileName: string);
    function ToYamlString: string;
  end;

implementation

{ TTemplateDTO }

constructor TTemplateDTO.Create;
begin
  inherited Create;
  RegexpAccept := TStringList.Create;
end;

destructor TTemplateDTO.Destroy;
begin
  RegexpAccept.Free;
  inherited;
end;

{ TConfigDefaultsDTO }

constructor TConfigDefaultsDTO.Create;
begin
  inherited;
  Qbittorrent := TQbittorrentDTO.Create;
  DefaultTemplates := TStringList.Create;
end;

destructor TConfigDefaultsDTO.Destroy;
begin
  Qbittorrent.Free;
  DefaultTemplates.Free;
  inherited;
end;


{ TFlexgetConfigDTO }

constructor TFlexgetConfigDTO.Create;
begin
  inherited Create;
  Defaults := TConfigDefaultsDTO.Create;
  Templates := TDictionary<string, TTemplateDTO>.Create;
  Tasks := TDictionary<string, TTaskDTO>.Create;
  Schedules := TObjectList<TScheduleDTO>.Create(True);
end;

destructor TFlexgetConfigDTO.Destroy;
var
  LTpl: TTemplateDTO;
  LTask: TTaskDTO;
begin
  Defaults.Free;

  for LTpl in Templates.Values do
    LTpl.Free;
  Templates.Free;

  for LTask in Tasks.Values do
    LTask.Free;
  Tasks.Free;

  Schedules.Free;
  inherited;
end;

procedure TFlexgetConfigDTO.LoadFromYamlFile(const AFileName: string);
var
  LLines: TStringList;
  LLine, LLineContent, LKey, LValue: string;
  LLevel, LPos, I: Integer;
  LCurrentSection, LCurrentSubSection, LCurrentSubSubSection: string;
  LCurrentTemplate: TTemplateDTO;
  LCurrentTask: TTaskDTO;
  LCurrentSchedule: TScheduleDTO;
  LIsListItem: Boolean;

  function GetIndentLevel(const ALine: string): Integer;
  var
    LIdx: Integer;
  begin
    Result := 0;
    for LIdx := 1 to Length(ALine) do
      if ALine[LIdx] = ' ' then
        Inc(Result)
      else
        Break;
    Result := Result div 2;
  end;

begin
  Self.Templates.Clear;
  Self.Tasks.Clear;
  Self.Schedules.Clear;
  // Limpa tambÚm as configuraþ§es padrÒo
  Self.Defaults.Qbittorrent.Host := '';
  Self.Defaults.Qbittorrent.Port := 0;
  Self.Defaults.Qbittorrent.Username := '';
  Self.Defaults.Qbittorrent.Password := '';
  Self.Defaults.RssAllEntries := '';
  Self.Defaults.DefaultTemplates.Clear;

  LLines := TStringList.Create;
  try
    LLines.LoadFromFile(AFileName);

    LCurrentSection := '';
    LCurrentSubSection := '';
    LCurrentSubSubSection := '';
    LCurrentTemplate := nil;
    LCurrentTask := nil;
    LCurrentSchedule := nil;

    for I := 0 to LLines.Count - 1 do
    begin
      LLine := LLines[I];
      if (Trim(LLine) = '') or (Trim(LLine).StartsWith('#')) then
        Continue;

      LLevel := GetIndentLevel(LLine);
      LLineContent := Trim(Copy(LLine, (LLevel * 2) + 1, MaxInt));

      if LLevel = 0 then
      begin
        LCurrentSection := ''; LCurrentSubSection := ''; LCurrentSubSubSection := '';
        LCurrentTemplate := nil; LCurrentTask := nil; LCurrentSchedule := nil;
      end
      else if LLevel = 1 then
      begin
        LCurrentSubSection := ''; LCurrentSubSubSection := '';
      end
      else if LLevel = 2 then
      begin
        LCurrentSubSubSection := '';
      end;

      LPos := Pos(':', LLineContent);
      LIsListItem := LLineContent.StartsWith('-');

      if LIsListItem then
      begin
        LKey := '-'; LValue := Trim(LLineContent.Substring(1));
      end
      else if LPos > 0 then
      begin
        LKey := Trim(Copy(LLineContent, 1, LPos - 1));
        LValue := Trim(Copy(LLineContent, LPos + 1, MaxInt));
      end
      else
      begin
        LKey := LLineContent; LValue := '';
      end;

      case LLevel of
        0: // Seþ§es principais: defaults, templates, tasks, schedules
          begin
            LCurrentSection := LKey;
          end;
        1: // Subseþ§es (qbittorrent, rss) ou itens nomeados
          begin
            if LCurrentSection = 'defaults' then
            begin
                LCurrentSubSection := LKey;
            end
            else if LCurrentSection = 'templates' then
            begin
              LCurrentTemplate := TTemplateDTO.Create;
              Self.Templates.Add(LKey, LCurrentTemplate);
            end
            else if LCurrentSection = 'tasks' then
            begin
              LCurrentTask := TTaskDTO.Create;
              Self.Tasks.Add(LKey, LCurrentTask);
            end
            else if (LCurrentSection = 'schedules') and LIsListItem then
            begin
              LCurrentSchedule := TScheduleDTO.Create;
              Self.Schedules.Add(LCurrentSchedule);
              if LKey = 'tasks' then LCurrentSchedule.Tasks := LValue;
            end;
          end;
        2: // Propriedades
          begin
            if LCurrentSection = 'defaults' then
            begin
                if LCurrentSubSection = 'qbittorrent' then
                begin
                    if LKey = 'host' then Self.Defaults.Qbittorrent.Host := LValue
                    else if LKey = 'port' then Self.Defaults.Qbittorrent.Port := StrToIntDef(LValue, 0)
                    else if LKey = 'username' then Self.Defaults.Qbittorrent.Username := LValue
                    else if LKey = 'password' then Self.Defaults.Qbittorrent.Password := LValue;
                end
                else if LCurrentSubSection = 'rss' then
                begin
                    if LKey = 'all_entries' then Self.Defaults.RssAllEntries := LValue;
                end
                else if LCurrentSubSection = 'template' then // Aqui Ú a lista de templates padrÒo
                begin
                    if LKey = '-' then Self.Defaults.DefaultTemplates.Add(LValue);
                end;
            end
            else if (LCurrentSection = 'templates') and (LCurrentTemplate <> nil) then
            begin
              LCurrentSubSection := LKey;
              if LKey = 'accept_all' then LCurrentTemplate.AcceptAll := LValue
              else if LKey = 'magnets' then LCurrentTemplate.Magnets := LValue;
            end
            else if (LCurrentSection = 'tasks') and (LCurrentTask <> nil) then
            begin
              // Agora a task s¾ tem url e path
              LCurrentSubSection := LKey;
              if LKey = 'url' then LCurrentTask.RssUrl := LValue
              else if LKey = 'path' then LCurrentTask.QbitPath := LValue;
            end
            else if (LCurrentSection = 'schedules') and (LCurrentSchedule <> nil) then
            begin
              LCurrentSubSection := LKey;
              if LKey = 'tasks' then LCurrentSchedule.Tasks := LValue;
            end;
          end;
        3: // Sub-propriedades (min, accept, etc)
          begin
            if (LCurrentSection = 'templates') and (LCurrentTemplate <> nil) then
            begin
              if LCurrentSubSection = 'regexp' then
                LCurrentSubSubSection := LKey
              else if LCurrentSubSection = 'content_size' then
              begin
                if LKey = 'min' then
                  LCurrentTemplate.ContentSizeMin := StrToIntDef(LValue, 0);
              end;
            end
            else if (LCurrentSection = 'schedules') and (LCurrentSchedule <> nil) then
            begin
                if LCurrentSubSection = 'interval' then
                begin
                    if LKey = 'minutes' then LCurrentSchedule.IntervalMinutes := StrToIntDef(LValue, 0);
                end;
            end;
          end;
        4: // Apenas para a lista de regex
          begin
            if (LCurrentSection = 'templates') and (LCurrentTemplate <> nil) and
               (LCurrentSubSection = 'regexp') and (LCurrentSubSubSection = 'accept') then
            begin
              if LKey = '-' then
                LCurrentTemplate.RegexpAccept.Add(LValue);
            end;
          end;
      end;
    end;
  finally
    LLines.Free;
  end;
end;

function TFlexgetConfigDTO.ToYamlString: string;
var
  LBuilder: TStringBuilder;
  LKey, LItem: string;
  LTemplate: TTemplateDTO;
  LTask: TTaskDTO;
  LSchedule: TScheduleDTO;
begin
  LBuilder := TStringBuilder.Create;
  try
    // --- Defaults ---
    LBuilder.AppendLine('defaults:');
    LBuilder.AppendLine('  qbittorrent:');
    LBuilder.AppendLine('    host: ' + Self.Defaults.Qbittorrent.Host);
    LBuilder.AppendLine('    port: ' + Self.Defaults.Qbittorrent.Port.ToString);
    LBuilder.AppendLine('    username: ' + Self.Defaults.Qbittorrent.Username);
    LBuilder.AppendLine('    password: ' + Self.Defaults.Qbittorrent.Password);
    LBuilder.AppendLine('  rss:');
    LBuilder.AppendLine('    all_entries: ' + Self.Defaults.RssAllEntries);
    LBuilder.AppendLine('  template:');
    for LItem in Self.Defaults.DefaultTemplates do
      LBuilder.AppendLine('    - ' + LItem);
    LBuilder.AppendLine;

    // --- Templates ---
    if Self.Templates.Count > 0 then
    begin
      LBuilder.AppendLine('templates:');
      for LKey in Self.Templates.Keys do
      begin
        LTemplate := Self.Templates[LKey];
        LBuilder.AppendLine('  ' + LKey + ':');
        LBuilder.AppendLine('    accept_all: ' + LTemplate.AcceptAll);
        LBuilder.AppendLine('    magnets: ' + LTemplate.Magnets);
        if LTemplate.ContentSizeMin > 0 then
        begin
          LBuilder.AppendLine('    content_size:');
          LBuilder.AppendLine('      min: ' + LTemplate.ContentSizeMin.ToString);
        end;
        if LTemplate.RegexpAccept.Count > 0 then
        begin
          LBuilder.AppendLine('    regexp:');
          LBuilder.AppendLine('      accept:');
          for LItem in LTemplate.RegexpAccept do
            LBuilder.AppendLine('        - ' + LItem);
        end;
      end;
      LBuilder.AppendLine;
    end;

    // --- Tasks ---
    if Self.Tasks.Count > 0 then
    begin
      LBuilder.AppendLine('tasks:');
      for LKey in Self.Tasks.Keys do
      begin
        LTask := Self.Tasks[LKey];
        LBuilder.AppendLine('  ' + LKey + ':');
        LBuilder.AppendLine('    url: ' + LTask.RssUrl);
        LBuilder.AppendLine('    path: ' + LTask.QbitPath);
      end;
      LBuilder.AppendLine;
    end;

    // --- Schedules ---
    if Self.Schedules.Count > 0 then
    begin
      LBuilder.AppendLine('schedules:');
      for LSchedule in Self.Schedules do
      begin
        LBuilder.AppendLine('  - tasks: ' + LSchedule.Tasks);
        LBuilder.AppendLine('    interval:');
        LBuilder.AppendLine('      minutes: ' + LSchedule.IntervalMinutes.ToString);
      end;
    end;

    Result := LBuilder.ToString;
  finally
    LBuilder.Free;
  end;
end;

end.
